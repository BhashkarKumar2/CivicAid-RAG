LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Optional. The app works without Gemini using deterministic template answers.
GEMINI_API_KEY=

# Optional. Enables myScheme API-backed official source discovery.
MYSCHEME_API_KEY=

# Comma-separated browser origins allowed to call the API.
# Keep this narrow in production.
CIVICAID_CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
